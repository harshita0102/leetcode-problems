#include <stdio.h>

int lengthOfLongestSubstring(char* s) {
    int count[256] = {0}; // Tracks if a character is inside our current window
    int maxLength = 0;
    int left = 0;

    for (int right = 0; s[right] != '\0'; right++) {
        // While the current character is a duplicate, shrink the window from the left
        while (count[(unsigned char)s[right]] > 0) {
            count[(unsigned char)s[left]]--;
            left++;
        }

        // Add the current character to the window
        count[(unsigned char)s[right]]++;

        // Calculate window size and update max length
        int currentLength = right - left + 1;
        if (currentLength > maxLength) {
            maxLength = currentLength;
        }
    }

    return maxLength;
}

