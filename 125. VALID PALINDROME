bool isPalindrome(char* s) {
    int left=0;
    int right=strlen(s)-1;
    while(left<right){
        while(left<right && !isalnum((unsigned int)s[left])){
            left++;
        }
        while(left<right && !isalnum((unsigned int)s[right])){
            right--;
        }
        if(tolower((unsigned int)s[left]) != tolower((unsigned int)s[right])){
            return false;
        }
        left ++;
        right--;
    }
    return true;
}
